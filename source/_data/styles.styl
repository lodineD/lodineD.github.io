// 自定义暗色主题样式 - 匹配 lodineD.github.io 风格

// 深色背景覆盖
html, body
  background: #0a0a1a !important

// 星空 canvas
#star-canvas
  position: fixed !important
  top: 0
  left: 0
  width: 100%
  height: 100%
  z-index: 0
  pointer-events: none

// 内容层叠
.container
  position: relative
  z-index: 1

// Header 透明
.header
  background: transparent !important

// 文章区块透明背景
.post-block
  background: transparent !important

// 侧边栏深色
.sidebar
  background: #111 !important

// 链接颜色
a
  color: #ccc
  &:hover
    color: #fff

// 文章标题颜色
.post-title, .post-title a
  color: #e0e0e0 !important
  &:hover
    color: #fff !important

// 文章正文颜色
.post-body
  color: #ccc

// 侧边栏深色背景
.sidebar-inner
  color: #999

// Footer
.footer
  color: #666

// 代码块深色背景
.highlight, pre
  background: #1e1e2e !important
  color: #cdd6f4

code
  background: rgba(255,255,255,0.1) !important
  color: #e0e0e0

// 表格深色
table
  color: #ccc

tbody tr:nth-of-type(odd)
  background: rgba(255,255,255,0.03)

tbody tr:hover
  background: rgba(255,255,255,0.08)

th, td
  border-color: rgba(255,255,255,0.1) !important

// 引用块
blockquote
  border-left-color: rgba(162,155,254,0.5) !important
  color: #aaa

// 分页
.pagination
  border-top-color: rgba(255,255,255,0.1) !important

.pagination .prev,
.pagination .next,
.pagination .page-number
  border-bottom-color: rgba(255,255,255,0.1) !important
  border-top-color: rgba(255,255,255,0.1) !important
  color: #ccc
  &:hover
    border-top-color: #a29bfe !important
    color: #fff

// HR 样式
hr
  background-image: repeating-linear-gradient(-45deg, rgba(255,255,255,0.2), rgba(255,255,255,0.2) 4px, transparent 4px, transparent 8px) !important

// Menu 样式
.menu-item a, .menu-item span.exturl
  color: #ccc !important
  &:hover
    color: #fff !important
    border-bottom-color: #a29bfe !important

// 渐变 accent 颜色
.brand
  color: #fff !important
  &:hover
    color: #fff !important

// 文章标签
.post-tags a
  color: #a29bfe !important
  &:hover
    color: #fff !important

// Post meta
.post-meta
  color: #888 !important

// 回到顶部
.back-to-top
  background: rgba(30,30,40,0.8) !important
  color: #a29bfe !important
  &:hover
    color: #fff !important

// Headband
.headband
  background: linear-gradient(90deg, #a29bfe, #fd79a8) !important
  height: 3px !important
